<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Cuestionario</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container py-5">
    <h1 class="mb-4 text-center">Cuestionario - <%= tema.replace('_',' ') %></h1>

    <% if (!resultado || !resultado.puntaje) { %>
        <!-- FORMULARIO DEL QUIZ -->
        <form action="/resultado/<%= tema %>" method="post" class="card p-4 shadow-sm">

          <% preguntas.forEach((p, index)=> { %>
            <div class="mb-4">
              <p><strong>
                  <%= index + 1 %>. <%= p.pregunta %>
                </strong></p>

              <!-- 🔥 NUEVO: Mostrar imagen solo si existe -->
              <% if (p.imagen) { %>
                <div class="text-center mb-3">
                  <img src="<%= p.imagen %>" alt="Imagen de la pregunta" class="img-fluid rounded shadow-sm"
                    style="max-height: 300px;" loading="lazy" onerror="this.style.display='none'">
                </div>
                <% } %>

                  <% p.opciones.forEach((opcion, i)=> {
                    const id = `p${index}_op${i}`;
                    %>
                    <div class="form-check">
                      <input id="<%= id %>" class="form-check-input" type="radio" name="pregunta_<%= index %>"
                        value="<%= opcion %>" required>
                      <label for="<%= id %>" class="form-check-label">
                        <%= opcion %>
                      </label>
                    </div>
                    <% }) %>

            </div>
            <% }) %>

              <div class="text-center">
                <button type="submit" class="btn btn-primary">Enviar respuestas</button>
                <a href="/" class="btn btn-dark">Volver al menú</a>
              </div>

        </form>

        <% } else { %>
          <!-- RESULTADOS DEL QUIZ -->
          <div class="card shadow-sm p-4">

            <h2 class="mb-3">Resultado</h2>
            <p class="fs-5">Tu puntuación: <strong>
                <%= resultado.puntaje %> / <%= resultado.total %>
              </strong></p>

            <% if (resultado.errores.length> 0) { %>
              <div class="mt-4">
                <h4>Preguntas incorrectas:</h4>

                <ul class="list-group">
                  <% resultado.errores.forEach(e=> { %>
                    <li class="list-group-item">

                      <strong>
                        <%= e.pregunta %>
                      </strong><br>

                      <!-- 🔥 NUEVO: Mostrar imagen si existe -->
                      <% if (e.imagen) { %>
                        <div class="text-center my-2">
                          <img src="<%= e.imagen %>" class="img-fluid rounded shadow-sm" style="max-height: 250px;"
                            loading="lazy" onerror="this.style.display='none'">
                        </div>
                        <% } %>

                          Tu respuesta:
                          <span class="text-danger">
                            <%= e.respuestaUsuario %>
                          </span><br>

                          Correcta:
                          <span class="text-success">
                            <%= e.respuestaCorrecta %>
                          </span>

                    </li>
                    <% }) %>
                </ul>

              </div>
              <% } else { %>
                <div class="alert alert-success mt-3">¡Todas tus respuestas son correctas! 🎉</div>
                <% } %>

                  <div class="text-center mt-4">
                    <a href="/quiz/<%= tema %>" class="btn btn-secondary me-2">Repetir tema</a>
                    <a href="/" class="btn btn-dark">Volver al menú</a>
                  </div>
          </div>
          <% } %>
  </div>

</body>

</html>