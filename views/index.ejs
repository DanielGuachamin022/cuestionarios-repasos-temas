<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Seleccionar Tema</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container py-5">
    <h1 class="text-center mb-4">Selecciona un Tema</h1>

    <div class="list-group shadow-sm">

        <% for (let clave in temas) { %>
            <a href="/quiz/<%= clave %>" class="list-group-item list-group-item-action fs-5">
                <%= clave.replace(/_/g, " ").toUpperCase() %>
            </a>
        <% } %>

    </div>
</div>

</body>
</html>
